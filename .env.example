# =============================================================================
# ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values

# Environment
ENV=development
DEBUG=false

# =============================================================================
# DATABASE CONFIGURATION (MongoDB Only)
# =============================================================================

# MongoDB Connection URL (for all data storage: sessions, lesson plans, chat history)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=doclearn

# =============================================================================
# LLM API KEYS (Gemini Only)
# =============================================================================

# Google API Key (for all Gemini models)
# Get from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here

# =============================================================================
# LLM MODEL CONFIGURATION (Optional - defaults provided)
# =============================================================================

# Available models: gemini-2.5-pro, gemini-2.5-flash, gemini-1.5-pro, gemini-1.5-flash
# Planning Model - For curriculum generation (needs strong reasoning)
# PLANNING_MODEL=gemini-2.5-pro

# Tutoring Model - For interactive teaching (needs speed)
# TUTORING_MODEL=gemini-2.5-flash

# =============================================================================
# STREAMING CONFIGURATION
# =============================================================================

# Token threshold for streaming vs burst response
# - Below threshold: Burst (immediate full response)
# - At or above threshold: Stream (token by token)
# STREAMING_TOKEN_THRESHOLD=100

# =============================================================================
# MEMORY BUFFER CONFIGURATION
# =============================================================================

# Number of messages before triggering summarization
# When buffer reaches this size, messages are summarized and cleared
# MEMORY_BUFFER_SIZE=10

# =============================================================================
# QDRANT CLOUD CONFIGURATION (Required for RAG/Book Tutor mode)
# =============================================================================

# Get from: https://cloud.qdrant.io
QDRANT_URL=https://your-cluster.cloud.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key-here

# Collection prefix (each session gets prefix_sessionid)
# QDRANT_COLLECTION_PREFIX=rag

# =============================================================================
# RAG CONFIGURATION (Optional - defaults provided)
# =============================================================================

# Embedding model (uses Google API key, no extra key needed)
# EMBEDDING_MODEL=models/text-embedding-004

# Text chunking settings
# RAG_CHUNK_SIZE=1000
# RAG_CHUNK_OVERLAP=200
# RAG_TOP_K=5
# RAG_MAX_FILE_SIZE_MB=50

# =============================================================================
# SERVICE CONFIGURATION (Optional - defaults provided)
# =============================================================================

# SERVICE_NAME=generation_service
# SERVICE_VERSION=1.0.0
